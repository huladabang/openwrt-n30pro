CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_HAS_SUBTARGETS=y

# 只编译 N30Pro 这一个设备
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_netcore_n30pro=y
CONFIG_TARGET_DEVICE_PACKAGES_mediatek_filogic_DEVICE_netcore_n30pro="kmod-usb3 kmod-usb-ledtrig-usbport kmod-usb-net-cdc-ncm kmod-usb-net-cdc-ether kmod-usb-net-rndis kmod-usb-serial-option"

# ===== 基础编译选项 =====
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_BUSYBOX_CUSTOM=y
CONFIG_JSON_OVERVIEW_IMAGE_INFO=y
CONFIG_INCLUDE_CONFIG=y

# ===== MT7981 WiFi 驱动 (immortalwrt 专用 MTK 闭源驱动) =====
CONFIG_BUSYBOX_CONFIG_BLKID=y
CONFIG_BUSYBOX_CONFIG_FEATURE_BLKID_TYPE=y
CONFIG_BUSYBOX_CONFIG_VOLUMEID=y
CONFIG_CONNINFRA_AUTO_UP=y
CONFIG_CONNINFRA_EMI_SUPPORT=y

# ===== 内核模块 =====
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-nls-cp437=y
CONFIG_PACKAGE_kmod-nls-iso8859-1=y
CONFIG_PACKAGE_kmod-nls-utf8=y
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-scsi-core=y
CONFIG_PACKAGE_kmod-ata-core=y

# USB 3.0 支持
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-ledtrig-usbport=y

# USB 网络共享 (网络共享/上网)
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ncm=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-ipheth=y

# USB 4G/5G 上网
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y

# ===== OpenClash 依赖 =====
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat-extra=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nf-tproxy=y
CONFIG_PACKAGE_kmod-ipt-conntrack-extra=y
CONFIG_PACKAGE_kmod-inet-diag=y

# ===== 基础工具 =====
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ethtool=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_wireless-tools=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y
CONFIG_PACKAGE_mii_mgr=y
CONFIG_PACKAGE_switch=y
CONFIG_PACKAGE_mtk-smp=y
# CONFIG_PACKAGE_wifi-scripts=y is not set
# CONFIG_PACKAGE_wifi-dats=y is not set
# CONFIG_PACKAGE_datconf=y is not set
# CONFIG_PACKAGE_datconf-lua=y is not set
CONFIG_PACKAGE_kvcedit=y
# CONFIG_PACKAGE_mtkhqos_util=y is not set

# ===== 网络工具 =====
CONFIG_PACKAGE_ip-bridge=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ip6tables-extra=y
CONFIG_PACKAGE_ip6tables-nft=y
CONFIG_PACKAGE_iptables-mod-conntrack-extra=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_iptables-mod-filter=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-iprange=y
CONFIG_PACKAGE_iptables-mod-nat-extra=y
CONFIG_PACKAGE_tc-mod-iptables=y
CONFIG_PACKAGE_tc-tiny=y
CONFIG_PACKAGE_ebtables=y
CONFIG_PACKAGE_kmod-ebtables=y
CONFIG_PACKAGE_kmod-ebtables-ipv4=y
CONFIG_PACKAGE_kmod-ebtables-ipv6=y

# ===== USB 共享工具 =====
CONFIG_PACKAGE_kmod-ifb=y
CONFIG_PACKAGE_usbmuxd=y
CONFIG_PACKAGE_libimobiledevice=y

# ===== LuCI 界面 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# MTK 专用 LuCI 插件
# CONFIG_PACKAGE_luci-app-eqos-mtk=y is not set
# CONFIG_PACKAGE_luci-i18n-eqos-mtk-zh-cn=y is not set
# CONFIG_PACKAGE_luci-app-turboacc-mtk=y is not set
# CONFIG_PACKAGE_luci-i18n-turboacc-mtk-zh-cn=y is not set
# CONFIG_PACKAGE_luci-app-wrtbwmon=y is not set

# ===== 终端 (ttyd) =====
# CONFIG_PACKAGE_luci-app-ttyd=y is not set
# CONFIG_PACKAGE_ttyd=y is not set
# CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y is not set

# ===== 文件浏览 (filebrowser) =====
# CONFIG_PACKAGE_luci-app-filebrowser=y is not set

# ===== USB 网络共享 LuCI 插件 =====
# CONFIG_PACKAGE_luci-app-usbmodem=y is not set
CONFIG_PACKAGE_luci-proto-ncm=y

# ===== iStore 商店 =====
# iStore 通过 feeds 安装，这里预留包名
# CONFIG_PACKAGE_luci-app-store=y

# ===== OpenClash =====
# OpenClash 通过 feeds 安装
# CONFIG_PACKAGE_luci-app-openclash=y is not set

# ===== 库依赖 =====
CONFIG_PACKAGE_libatomic=y
CONFIG_PACKAGE_libblkid=y
CONFIG_PACKAGE_libcap-ng=y
CONFIG_PACKAGE_libcbor=y
CONFIG_PACKAGE_libipset=y
CONFIG_PACKAGE_libkvcutil=y
CONFIG_PACKAGE_libncurses=y
CONFIG_PACKAGE_libnl=y
CONFIG_PACKAGE_libpcap=y
CONFIG_PACKAGE_libstdcpp=y
CONFIG_PACKAGE_libuuid=y
CONFIG_PACKAGE_lua-cjson=y
CONFIG_PACKAGE_libopenssl-afalg_sync=y
CONFIG_PACKAGE_libopenssl-devcrypto=y
CONFIG_PACKAGE_terminfo=y

# ===== 安全 =====
CONFIG_PACKAGE_openssh-keygen=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_openssl-util=y

# ===== 性能优化 =====
# CONFIG_PACKAGE_TURBOACC_INCLUDE_NO_FASTPATH=y is not set
# CONFIG_PACKAGE_TURBOACC_INCLUDE_FLOW_OFFLOADING is not set
CONFIG_PKG_FORTIFY_SOURCE_2=y
# CONFIG_PKG_CHECK_FORMAT_SECURITY is not set

# ===== 中文支持 =====
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
# 禁用可能编译失败的第三方 5G 模块驱动 (Linux 6.6 内核兼容性差)
# CONFIG_PACKAGE_kmod-qmi_wwan_f is not set
# CONFIG_PACKAGE_kmod-qmi_wwan_q is not set
# CONFIG_PACKAGE_kmod-qmi_wwan_m is not set
# CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-quectel is not set
# CONFIG_PACKAGE_kmod-usb-net-qmi-wwan-fibocom is not set
